# ============================================================
# Health Dashboard — Environment Variables
# Copy this file to .env and fill in all required values.
# ============================================================

# --- Database (auth and preferences only — no health data) ---
DATABASE_URL=postgresql://health:health@localhost:5432/health
POSTGRES_USER=health
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=health

# --- Server ---
PORT=3001
HOST=0.0.0.0
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# --- Auth (Better Auth) ---
# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
# Public-facing URL of the app (used to construct magic link URLs in emails).
# - Docker Compose: use the web service URL (http://localhost:5173) so links go through nginx
# - pnpm dev (no Docker): use the Fastify server URL (http://localhost:3001)
# - Production: use your public domain (https://app.example.com)
BETTER_AUTH_URL=http://localhost:5173

# --- Email (Resend) ---
# Used to send magic link sign-in emails.
# Sign up for a free API key at https://resend.com (3,000 emails/month free).
# Leave empty in local dev — magic links are printed to the server console instead.
RESEND_API_KEY=
# Sender address for magic link emails. Must use a domain verified in your Resend account.
# Falls back to noreply@resend.dev (only delivers to your own address — dev/testing only).
# Format: "Display Name <address@yourdomain.com>"
RESEND_FROM=Health Dashboard <noreply@yourdomain.com>

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=your-api-key-here

# --- Web app (VITE_ prefix exposes to the browser) ---
# FHIR Terminology Server — used for SNOMED CT lookups
# Default: https://browser.ihtsdotools.org/fhir
VITE_FHIR_TERMINOLOGY_URL=https://browser.ihtsdotools.org/fhir
# API base URL (where the server is running, as seen from the browser)
VITE_API_URL=http://localhost:3001

# --- Production Docker Compose overrides ---
# Port mappings for production containers (docker-compose.prod.yml only)
WEB_PORT=80
SERVER_PORT=3001

# NPM compose only: name of the external Docker network that nginx-proxy-manager is on.
# Create it once with: docker network create proxy
# Default: proxy
PROXY_NETWORK_NAME=proxy

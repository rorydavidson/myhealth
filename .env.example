# ============================================================
# Health Dashboard — Environment Variables
# Copy this file to .env and fill in all required values.
# ============================================================

# --- Database (auth and preferences only — no health data) ---
DATABASE_URL=postgresql://health:health@localhost:5432/health
POSTGRES_USER=health
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=health

# --- Server ---
PORT=3001
HOST=0.0.0.0
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# --- Auth (Better Auth) ---
# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
# Full URL where the server is accessible (used for OAuth callbacks)
BETTER_AUTH_URL=http://localhost:3001

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=your-api-key-here

# --- Web app (VITE_ prefix exposes to the browser) ---
# FHIR Terminology Server — used for SNOMED CT lookups
# Default: https://r4.ontoserver.csiro.au/fhir
VITE_FHIR_TERMINOLOGY_URL=https://r4.ontoserver.csiro.au/fhir
# API base URL (where the server is running, as seen from the browser)
VITE_API_URL=http://localhost:3001

# --- Production Docker Compose overrides ---
# Port mappings for production containers
WEB_PORT=80
SERVER_PORT=3001
